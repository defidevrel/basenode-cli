{
  "name": "basenode-cli",
  "version": "0.1.0",
  "description": "CLI for Base node operators — base/node setup, Azul preflight, compose day-2 ops",
  "type": "module",
  "bin": {
    "basenode": "dist/cli.js"
  },
  "main": "./dist/cli.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/defidevrel/basenode-cli.git"
  },
  "bugs": {
    "url": "https://github.com/defidevrel/basenode-cli/issues"
  },
  "homepage": "https://github.com/defidevrel/basenode-cli#readme",
  "keywords": [
    "base",
    "base-node",
    "ethereum",
    "reth",
    "docker",
    "flashblocks",
    "azul",
    "cli"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "assets",
    "scripts/postinstall-welcome.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "postinstall": "node scripts/postinstall-welcome.mjs",
    "prepack": "npm run build",
    "start": "node dist/cli.js",
    "basenode": "node dist/cli.js",
    "test": "npm run build && node --test test/*.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
